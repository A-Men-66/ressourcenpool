# Kopieren zu .env und Werte anpassen

# PostgreSQL Verbindung
DATABASE_URL=postgresql://rp_user:PASSWORT@localhost:5432/ressourcenpool

# JWT Secret (langen zufälligen String verwenden!)
JWT_SECRET=bitte-einen-langen-zufaelligen-string-hier-eintragen

# Server Port (3001, da Schwarm-App Port 3000 belegt)
PORT=3001
